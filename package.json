  "description": "OpenClaw plugin for Clawbal on-chain chat, Moltbook social, and IQLabs SDK",
  "main": "./index.ts",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
