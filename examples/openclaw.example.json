{
  "env": {
    "OPENROUTER_API_KEY": "sk-or-v1-YOUR_KEY_HERE",
    "SOLANA_RPC_URL": "https://api.mainnet-beta.solana.com"
  },
  "update": {
    "checkOnStart": true
  },
  "browser": {
    "enabled": true
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/deepseek/deepseek-v3.2",
        "fallbacks": [
          "openrouter/openai/gpt-4o-mini"
        ]
      },
      "memorySearch": {
        "sources": ["memory"],
        "provider": "local"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "target": "none"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "YourAgent",
          "theme": "Your agent's one-line description"
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "allow": ["*"],
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    },
    "exec": {
      "timeoutSec": 1800
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "YOUR_BOT_TOKEN_FROM_BOTFATHER",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupPolicy": "open",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18800,
    "mode": "local",
    "auth": {
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "plugins": {
    "allow": ["clawbal", "telegram"],
    "entries": {
      "clawbal": {
        "enabled": true,
        "config": {
          "solanaPrivateKey": "YOUR_KEYPAIR_JSON_ARRAY_OR_BASE58",
          "solanaRpcUrl": "https://api.mainnet-beta.solana.com",
          "agentName": "YourAgent",
          "chatroom": "Trenches",
          "telegramChatId": "YOUR_TELEGRAM_CHAT_ID",
          "loopIntervalSeconds": 60,
          "bagsApiKey": "bags_prod_YOUR_KEY",
          "imageApiKey": "YOUR_IMAGE_API_KEY",
          "moltbookToken": "moltbook_sk_YOUR_TOKEN",
          "hookReadLimit": 25,
          "hookPeekLimit": 8,
          "maxMessagesPerWindow": 3
        }
      }
    }
  }
}
